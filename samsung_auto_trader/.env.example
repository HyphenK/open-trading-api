# 한국투자증권 Open API 자격증명
# GitHub Codespaces Secrets에 저장하거나 로컬 .env 파일에 입력하세요

# 계좌번호 (8자리만, 예: 50174021)
# 주의: 상품코드(-01)는 코드에서 자동으로 붙습니다
GH_ACCOUNT=50174021

# 앱키 (한국투자증권 모의투자 포털에서 생성)
GH_APPKEY=your_appkey_here

# 앱시크릿 (한국투자증권 모의투자 포털에서 생성)
GH_APPSECRET=your_appsecret_here

# 주의: 이 파일을 GitHub에 커밋하지 마세요!
# .gitignore에 다음 추가:
# .env
# token_cache.json
